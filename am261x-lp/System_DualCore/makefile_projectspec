
export MCU_PLUS_SDK_PATH?=$(abspath ../../../../../..)
include $(MCU_PLUS_SDK_PATH)/imports.mak

export PROFILE?=Release

PROJECT_NAME=System_DualCore

all:
	$(CCS_ECLIPSE) -noSplash -workspace $(MCU_PLUS_SDK_PATH)/ccs_projects -application com.ti.ccs.apps.projectBuild -ccs.projects $(PROJECT_NAME) -ccs.configuration $(PROFILE)

clean:
	$(CCS_ECLIPSE) -noSplash -workspace $(MCU_PLUS_SDK_PATH)/ccs_projects -application com.ti.ccs.apps.projectBuild -ccs.projects $(PROJECT_NAME) -ccs.configuration $(PROFILE) -ccs.clean
	$(MAKE) -C ../Core0-freertos/ti-arm-clang/ -f makefile_projectspec clean
	$(MAKE) -C ../Core1_nortos/ti-arm-clang/ -f makefile_projectspec clean

export:
	$(MKDIR) $(MCU_PLUS_SDK_PATH)/ccs_projects
	$(CCS_ECLIPSE) -noSplash -workspace $(MCU_PLUS_SDK_PATH)/ccs_projects -application com.ti.ccs.apps.projectCreate -ccs.projectSpec system.projectspec -ccs.overwrite full
